{
  "name": "ardm-next",
  "version": "0.1.0",
  "private": true,
  "description": "AnotherRedisDesktopManager next app scaffold (Electron + Vite + Vue3)",
  "main": "apps/main/src/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config apps/renderer/vite.config.js",
    "dev:electron": "wait-on tcp:5173 && cross-env ARDM_NEXT_RENDERER_URL=http://127.0.0.1:5173 electron apps/main/src/main.js",
    "build": "npm run build:renderer",
    "build:renderer": "vite build --config apps/renderer/vite.config.js",
    "start": "electron apps/main/src/main.js"
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "tunnel-ssh": "^5.2.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "vite": "^5.4.19",
    "wait-on": "^8.0.1"
  }
}
